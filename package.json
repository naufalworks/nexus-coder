{
  "name": "nexus-coder",
  "version": "0.1.0",
  "description": "Multi-agent AI coding assistant with git-native workflow and unlimited context memory",
  "main": "dist/cli/index.js",
  "bin": {
    "nexus": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "jest",
    "test:e2e": "jest --config jest.config.js --testPathPattern='tests/e2e' --verbose --forceExit --detectOpenHandles",
    "test:e2e:local": "jest --config jest.config.js --testPathPattern='tests/e2e/06|tests/e2e/07' --verbose --forceExit",
    "test:integration": "jest --testPathPattern='__tests__/integration'",
    "test:a11y": "jest --testPathPattern='__tests__/accessibility'",
    "test:performance": "jest --testPathPattern='__tests__/performance'",
    "test:security": "jest --testPathPattern='__tests__/security'",
    "test:visual": "jest --testPathPattern='__tests__/visual' --updateSnapshot",
    "audit:typescript": "ts-node src/__tests__/audit/typescript-strict.audit.ts",
    "audit:dead-code": "ts-node src/__tests__/audit/dead-code.audit.ts",
    "audit:security": "ts-node src/__tests__/audit/security.audit.ts",
    "audit:all": "npm run audit:typescript && npm run audit:dead-code && npm run audit:security",
    "test:qa": "npm run test && npm run test:integration && npm run test:a11y && npm run test:performance && npm run audit:all",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "coding-assistant",
    "multi-agent",
    "mcp",
    "git",
    "vector-database",
    "claude"
  ],
  "author": "naufalworks",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@qdrant/js-client-rest": "^1.12.0",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "diff": "^5.2.0",
    "dotenv": "^16.4.7",
    "inquirer": "^9.2.23",
    "openai": "^4.104.0",
    "ora": "^5.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "simple-git": "^3.27.0",
    "tiktoken": "^1.0.22",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.21.0",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.21.2",
    "uuid": "^10.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff": "^5.2.0",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.17.0",
    "eslint-plugin-security": "^3.0.1",
    "fast-check": "^4.7.0",
    "gzip-size": "^7.0.0",
    "jest": "^29.7.0",
    "jest-axe": "^9.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
